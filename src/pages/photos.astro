---
import Layout from "../layouts/Layout.astro";
import { identity } from "../config";
import { Icon } from "astro-icon/components";

const photos = [
  {
    src: "https://img.mmddskq.top/file/blog/1784106117834_IMG_4339.JPG",
    width: 2560,
    height: 1920,
    alt: "skqfly 摄影作品 1",
  },
  {
    src: "https://img.mmddskq.top/file/blog/1784106119777_IMG_4555.JPG",
    width: 1920,
    height: 2560,
    alt: "skqfly 摄影作品 2",
  },
  {
    src: "https://img.mmddskq.top/file/blog/1784106123200_IMG_20260603_160516.JPG",
    width: 2560,
    height: 1920,
    alt: "skqfly 摄影作品 3",
  },
  {
    src: "https://img.mmddskq.top/file/blog/1784106188171_IMG_20260606_163316.JPG",
    width: 2560,
    height: 1920,
    alt: "skqfly 摄影作品 4",
  },
  {
    src: "https://img.mmddskq.top/file/blog/1784107108670_IMG_20260601_190827.JPG",
    width: 1920,
    height: 2560,
    alt: "skqfly 摄影作品 5",
  },
  {
    src: "https://img.mmddskq.top/file/blog/1784107109372_IMG_20260606_162539.JPG",
    width: 2560,
    height: 1920,
    alt: "skqfly 摄影作品 6",
  },
  {
    src: "https://img.mmddskq.top/file/blog/1784107115373_IMG_4398.JPG",
    width: 1920,
    height: 2560,
    alt: "skqfly 摄影作品 7",
  },
  {
    src: "https://img.mmddskq.top/file/blog/1784107114466_IMG_4461.JPG",
    width: 1920,
    height: 2560,
    alt: "skqfly 摄影作品 8",
  },
  {
    src: "https://img.mmddskq.top/file/blog/1784107112532_IMG_4516.JPG",
    width: 2560,
    height: 1920,
    alt: "skqfly 摄影作品 9",
  },
  {
    src: "https://img.mmddskq.top/file/blog/1784107109272_IMG_20260601_190536.JPG",
    width: 1920,
    height: 2560,
    alt: "skqfly 摄影作品 10",
  },
];

const seo = {
  title: "Photos | skqfly",
  description: "skqfly 的摄影与图像记录。",
  image: identity.logo,
};
---

<Layout seo={seo}>
  <section class="photos-page mx-auto mt-5 w-full px-4 sm:px-6 lg:px-8">
    <h1 class="sr-only">Photos</h1>

    <div class="mb-5 flex min-h-11 items-center">
      <button
        id="photo-layout-toggle"
        class="photo-layout-toggle inline-flex min-h-11 min-w-11 items-center justify-center rounded-lg opacity-60 transition-opacity hover:opacity-100"
        type="button"
        data-layout="fixed"
        aria-label="切换为原始比例布局"
        aria-pressed="false"
        title="切换为原始比例布局"
      >
        <Icon
          name="mdi:view-grid-outline"
          width={23}
          height={23}
          class="photo-layout-toggle__icon photo-layout-toggle__icon--fixed"
        />
        <Icon
          name="mdi:view-dashboard-outline"
          width={23}
          height={23}
          class="photo-layout-toggle__icon photo-layout-toggle__icon--original"
        />
      </button>
    </div>

    <ul id="photo-gallery" class="photo-gallery" data-layout="fixed">
      {
        photos.map((photo, index) => (
          <li class="photo-gallery__item">
            <button
              class="photo-gallery__trigger"
              type="button"
              data-photo-index={index}
              data-photo-src={photo.src}
              data-photo-alt={photo.alt}
              aria-label={`查看大图：${photo.alt}`}
            >
              <img
                src={photo.src}
                width={photo.width}
                height={photo.height}
                alt={photo.alt}
                loading={index === 0 ? "eager" : "lazy"}
                fetchpriority={index === 0 ? "high" : "auto"}
                decoding="async"
              />
            </button>
          </li>
        ))
      }
    </ul>
  </section>

  <dialog id="photo-lightbox" class="photo-lightbox" aria-label="照片大图预览">
    <button
      id="photo-lightbox-close"
      class="photo-lightbox__close"
      type="button"
      aria-label="关闭照片预览"
      title="关闭"
    >
      <Icon name="mdi:close" width={26} height={26} />
    </button>
    <img id="photo-lightbox-image" class="photo-lightbox__image" alt="" />
  </dialog>
</Layout>

<script>
  type PhotoLayout = "fixed" | "original";

  const gallery = document.getElementById("photo-gallery") as HTMLUListElement;
  const layoutToggle = document.getElementById(
    "photo-layout-toggle"
  ) as HTMLButtonElement;
  const lightbox = document.getElementById(
    "photo-lightbox"
  ) as HTMLDialogElement;
  const lightboxImage = document.getElementById(
    "photo-lightbox-image"
  ) as HTMLImageElement;
  const lightboxClose = document.getElementById(
    "photo-lightbox-close"
  ) as HTMLButtonElement;
  const photoTriggers = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".photo-gallery__trigger")
  );
  let lastPhotoTrigger: HTMLButtonElement | null = null;

  const setPhotoLayout = (layout: PhotoLayout) => {
    const isOriginal = layout === "original";
    const label = isOriginal
      ? "切换为固定方形布局"
      : "切换为原始比例布局";

    gallery.dataset.layout = layout;
    layoutToggle.dataset.layout = layout;
    layoutToggle.setAttribute("aria-pressed", String(isOriginal));
    layoutToggle.setAttribute("aria-label", label);
    layoutToggle.setAttribute("title", label);

    try {
      localStorage.setItem("photo-layout", layout);
    } catch {
      // Layout switching still works when storage is unavailable.
    }
  };

  let initialLayout: PhotoLayout = "fixed";
  try {
    initialLayout =
      localStorage.getItem("photo-layout") === "original"
        ? "original"
        : "fixed";
  } catch {
    // Use the fixed layout when storage is unavailable.
  }
  setPhotoLayout(initialLayout);

  layoutToggle.addEventListener("click", () => {
    setPhotoLayout(
      gallery.dataset.layout === "fixed" ? "original" : "fixed"
    );
  });

  for (const trigger of photoTriggers) {
    trigger.addEventListener("click", () => {
      lastPhotoTrigger = trigger;
      lightboxImage.src = trigger.dataset.photoSrc ?? "";
      lightboxImage.alt = trigger.dataset.photoAlt ?? "";
      lightbox.showModal();
    });
  }

  lightbox.addEventListener("click", (event) => {
    if (event.target === lightbox) {
      lightbox.close();
    }
  });

  lightboxClose.addEventListener("click", () => lightbox.close());

  lightbox.addEventListener("close", () => {
    lightboxImage.removeAttribute("src");
    lightboxImage.alt = "";
    lastPhotoTrigger?.focus();
  });
</script>

<style>
  .photo-layout-toggle {
    position: relative;
    color: var(--foreground);
  }

  .photo-layout-toggle__icon {
    position: absolute;
    transition:
      opacity 180ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .photo-layout-toggle__icon--original {
    opacity: 0;
    transform: scale(0.7) rotate(-18deg);
  }

  .photo-layout-toggle[data-layout="original"]
    .photo-layout-toggle__icon--fixed {
    opacity: 0;
    transform: scale(0.7) rotate(18deg);
  }

  .photo-layout-toggle[data-layout="original"]
    .photo-layout-toggle__icon--original {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .photo-gallery {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .photo-gallery[data-layout="fixed"] {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.75rem;
  }

  .photo-gallery__item {
    min-width: 0;
  }

  .photo-gallery__trigger {
    display: block;
    width: 100%;
    overflow: hidden;
    border: 0;
    border-radius: 0.25rem;
    background: var(--surface);
  }

  .photo-gallery__trigger img {
    display: block;
    width: 100%;
    transition:
      filter 220ms ease,
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .photo-gallery[data-layout="fixed"] .photo-gallery__trigger {
    aspect-ratio: 1;
  }

  .photo-gallery[data-layout="fixed"] .photo-gallery__trigger img {
    height: 100%;
    object-fit: cover;
  }

  .photo-gallery[data-layout="original"] {
    columns: 1;
    column-gap: 0.75rem;
  }

  .photo-gallery[data-layout="original"] .photo-gallery__item {
    break-inside: avoid;
    margin-bottom: 0.75rem;
  }

  .photo-gallery[data-layout="original"] .photo-gallery__trigger img {
    height: auto;
  }

  .photo-gallery__trigger:hover img {
    filter: brightness(0.9);
    transform: scale(1.015);
  }

  .photo-lightbox {
    width: 100vw;
    height: 100dvh;
    max-width: none;
    max-height: none;
    margin: 0;
    padding: clamp(2.5rem, 6vw, 5rem);
    border: 0;
    background: rgba(0, 0, 0, 0.58);
    color: #ffffff;
    overflow: hidden;
  }

  .photo-lightbox[open] {
    display: grid;
    place-items: center;
  }

  .photo-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(14px);
  }

  .photo-lightbox__image {
    display: block;
    max-width: min(86vw, 1100px);
    max-height: 82dvh;
    object-fit: contain;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
  }

  .photo-lightbox__close {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 1;
    display: inline-flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.38);
    color: #ffffff;
    opacity: 0.72;
    transition: opacity 180ms ease;
  }

  .photo-lightbox__close:hover {
    opacity: 1;
  }

  .photo-lightbox__close:focus-visible {
    outline-color: #ffffff;
  }

  @media (min-width: 640px) {
    .photo-gallery[data-layout="fixed"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .photo-gallery[data-layout="original"] {
      columns: 2;
    }
  }

  @media (min-width: 768px) {
    .photo-gallery[data-layout="fixed"] {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .photo-gallery[data-layout="original"] {
      columns: 4;
    }
  }
</style>

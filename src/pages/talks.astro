---
import Layout from "../layouts/Layout.astro";
import { talksPageContent } from "../config";
import BlogSectionNav from "../components/BlogSectionNav.astro";
import TalksGallery from "../components/talks/TalksGallery.jsx";
---

<Layout seo={talksPageContent.seo}>
  <section class="talks-page">
    <h1 class="sr-only">Talks</h1>
    <div class="talks-page__nav">
      <BlogSectionNav active="talks" />
      <p class="talks-page__intro">
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path
            d="M6 18c4.8-1.2 8.7-5.1 10-10M9.5 15.2c-1.8-.1-3.1-1-3.8-2.5 1.9-.4 3.5.1 4.6 1.2M13.5 11.4c-.1-1.8.7-3.2 2.2-4 0.5 1.8.1 3.5-1 4.7"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.45"
          />
        </svg>
        <span>{talksPageContent.subtitle}</span>
      </p>
    </div>
    <div class="talks-page__content">
      <TalksGallery entries={talksPageContent.entries} client:load />
    </div>
  </section>
</Layout>

<style>
  .talks-page {
    width: 100%;
    margin: 2.5rem 0 0;
  }

  .talks-page__nav {
    display: flow-root;
    width: 100%;
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2rem);
  }

  .talks-page__nav :global(.blog-section-nav) {
    margin-bottom: 0.65rem;
  }

  .talks-page__intro {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 clamp(1.5rem, 3vw, 2.25rem);
    font-size: 0.78rem;
    line-height: 1.5;
    opacity: 0.58;
  }

  .talks-page__intro svg {
    flex: none;
  }

  .talks-page__content {
    width: 100%;
    max-width: 74rem;
    margin: clamp(0.75rem, 1.5vw, 1rem) auto 0;
    padding: 0 clamp(1.25rem, 4vw, 2rem);
  }

  @media (max-width: 639px) {
    .talks-page {
      margin-top: 2rem;
    }
  }
</style>

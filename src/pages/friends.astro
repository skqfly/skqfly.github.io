---
import Layout from "../layouts/Layout.astro";
import { friendsPageContent } from "../config";
import { Icon } from "astro-icon/components";
---

<Layout seo={friendsPageContent.seo}>
  <section class="friends-page">
    <header class="friends-header">
      <h1>Friends</h1>
      <p>{friendsPageContent.subtitle}</p>
    </header>

    <ul class="friends-grid" aria-label="友情链接">
      {
        friendsPageContent.friends.map((friend) => (
          <li>
            <a
              class="friend-card"
              href={friend.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`访问 ${friend.title}（在新窗口打开）`}
            >
              <span class="friend-card__main">
                <span class="friend-card__avatar" aria-hidden="true">
                  <img
                    src={friend.image}
                    width="64"
                    height="64"
                    alt=""
                    loading="eager"
                    decoding="async"
                  />
                </span>

                <span class="friend-card__copy">
                  <span class="friend-card__title">{friend.title}</span>
                  <span class="friend-card__description">
                    {friend.description}
                  </span>
                </span>
              </span>

              <span class="friend-card__footer">
                <span class="friend-card__domain">
                  <Icon
                    name="mdi:link-variant"
                    width={18}
                    height={18}
                    aria-hidden="true"
                  />
                  <span>{friend.domain}</span>
                </span>
                <Icon
                  name="mdi:arrow-top-right"
                  width={20}
                  height={20}
                  class="friend-card__arrow"
                  aria-hidden="true"
                />
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  .friends-page {
    width: 100%;
    max-width: 64rem;
    margin: clamp(2.75rem, 7vw, 5rem) auto 0;
    padding: 0 clamp(1.25rem, 4vw, 2rem) 5rem;
  }

  .friends-header h1 {
    margin: 0;
    color: var(--foreground);
    font-family:
      "Iowan Old Style",
      "Palatino Linotype",
      "Book Antiqua",
      Palatino,
      Georgia,
      serif;
    font-size: clamp(2.25rem, 5vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  .friends-header p {
    margin: 0.75rem 0 0;
    color: var(--foreground);
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.68;
  }

  .friends-grid {
    display: grid;
    max-width: 23rem;
    grid-template-columns: minmax(0, 1fr);
    margin: clamp(2rem, 5vw, 3rem) 0 0;
    padding: 0;
    list-style: none;
  }

  .friend-card {
    display: flex;
    min-height: 12rem;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.35rem;
    border: 1px solid var(--border);
    border-radius: 0.9rem;
    background: var(--surface);
    color: var(--foreground);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.045);
    text-decoration: none;
    transition:
      border-color 180ms ease-out,
      box-shadow 220ms ease-out,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .friend-card__main {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    align-items: center;
    gap: 1.1rem;
  }

  .friend-card__avatar {
    display: grid;
    width: 4rem;
    height: 4rem;
    overflow: hidden;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: #ffffff;
  }

  .friend-card__avatar img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .friend-card__copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.4rem;
  }

  .friend-card__title {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .friend-card__description {
    font-size: 0.9rem;
    line-height: 1.5;
    opacity: 0.68;
  }

  .friend-card__footer {
    display: flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.35rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--border);
  }

  .friend-card__domain {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.85rem;
    opacity: 0.68;
  }

  .friend-card__domain span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .friend-card__arrow {
    flex: none;
    opacity: 0.48;
    transition:
      opacity 180ms ease-out,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .friend-card:hover {
    border-color: color-mix(in srgb, var(--foreground) 24%, transparent);
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.08);
    transform: translateY(-0.2rem);
  }

  .friend-card:hover .friend-card__arrow {
    opacity: 0.9;
    transform: translate(0.15rem, -0.15rem);
  }

  @media (max-width: 639px) {
    .friends-page {
      margin-top: 2.25rem;
    }

    .friends-grid {
      max-width: none;
    }

    .friend-card {
      min-height: 11rem;
      padding: 1.2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .friend-card,
    .friend-card__arrow {
      transition: none;
    }
  }
</style>

---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import { identity } from "../../config";
import "katex/dist/katex.min.css";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);
const wordCount = Number(remarkPluginFrontmatter.wordCount ?? 0);
const wordCountFormatter = new Intl.NumberFormat("zh-CN");
---

<Layout
  seo={{
    title: entry.data.title,
    description: entry.data.description,
    image: entry.data.image.url,
  }}
>
  <section class="mt-10 max-w-2xl mx-auto px-6">
    <h1 class="font-bold text-3xl mb-4">{entry.data.title}</h1>
    <p class="opacity-60 mb-6">
      {entry.data.description}
    </p>
    <div class="flex gap-4 mb-6">
      <Image
        src={identity.logo}
        alt={identity.name}
        width={40}
        height={40}
        class="brand-mark w-[40px] aspect-square object-contain"
      />
      <div>
        <p class="font-medium">{identity.name}</p>
        <p class="opacity-60">
            {entry.data.pubDate.toLocaleDateString()} · {wordCountFormatter.format(wordCount)} words
        </p>
      </div>
    </div>
    <Image
      src={entry.data.image.url}
      alt={entry.data.image.alt}
      width={800}
      height={300}
      class:list={[
        "surface-card aspect-video w-full rounded-xl mb-10 object-contain",
        entry.data.image.url === identity.logo && "brand-mark p-16",
      ]}
    />
    <article
      class="article-prose prose prose-headings:mb-2"
    >
      <Content />
    </article>
  </section>
</Layout>

<style is:global>
  .article-prose .katex-display {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.5rem 0;
  }

  .article-prose pre {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
  }

  .article-prose table {
    display: block;
    max-width: 100%;
    overflow-x: auto;
  }

  .article-prose img {
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
  }
</style>

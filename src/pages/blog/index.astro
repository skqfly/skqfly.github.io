---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { blogPageContent } from "../../config";
import { render } from "astro:content";
import BlogSectionNav from "../../components/BlogSectionNav.astro";

const posts = await getCollection("posts");
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
for (const post of posts) {
  const { remarkPluginFrontmatter } = await render(post);
  post.data.wordCount = remarkPluginFrontmatter.wordCount;
}

const postsByYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.pubDate.getFullYear();
  const yearPosts = postsByYear.get(year) ?? [];
  yearPosts.push(post);
  postsByYear.set(year, yearPosts);
}

const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
});
const wordCountFormatter = new Intl.NumberFormat("zh-CN");
const currentYear = new Date().getFullYear();
---

<Layout seo={blogPageContent.seo}>
  <section class="blog-index">
    <h1 class="sr-only">Blog</h1>
    <BlogSectionNav active="blogs" />

    <div class="blog-timeline">
      {
        Array.from(postsByYear.entries()).map(([year, yearPosts]) => (
          <section
            class="blog-year-group"
            aria-labelledby={year === currentYear ? undefined : `year-${year}`}
            aria-label={year === currentYear ? `${year} 年文章` : undefined}
          >
            {
              year !== currentYear && (
                <h2
                  id={`year-${year}`}
                  class="blog-year-heading"
                >
                  {year}
                </h2>
              )
            }
            <ol class="blog-year-posts">
              {yearPosts.map((post) => (
                <li class="blog-post-item">
                  <span aria-hidden="true" class="blog-timeline-dot" />
                  <a href={`/blog/${post.id}`} class="blog-post-row">
                    <h3 class="blog-post-title">{post.data.title}</h3>
                    <p class="blog-post-meta">
                      <time datetime={post.data.pubDate.toISOString().split("T")[0]}>
                        {dateFormatter.format(post.data.pubDate)}
                      </time>
                      <span aria-hidden="true"> · </span>
                      <span>{wordCountFormatter.format(post.data.wordCount ?? 0)} words</span>
                    </p>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .blog-index {
    width: 100%;
    max-width: 48rem;
    margin: 2.5rem auto 0;
    padding: 0 clamp(1.25rem, 4vw, 2rem);
  }

  .blog-index :global(.blog-section-nav) {
    margin-bottom: clamp(0.75rem, 2vw, 1rem);
  }

  .blog-timeline {
    font-family:
      "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino,
      Georgia, serif;
  }

  @media (min-width: 56rem) {
    .blog-timeline {
      margin-inline-start: -4.875rem;
    }
  }

  .blog-year-group {
    display: grid;
    grid-template-columns: 7rem minmax(0, 1fr);
  }

  .blog-year-heading {
    margin: 0;
    padding: 1.15rem 1.25rem 0 0;
    color: var(--foreground);
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 400;
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
    opacity: 0.52;
  }

  .blog-year-posts {
    position: relative;
    grid-column: 2;
    margin: 0;
    padding: 1rem 0 2rem 3rem;
    border-left: 1px solid var(--border);
    list-style: none;
  }

  .blog-post-item {
    position: relative;
  }

  .blog-timeline-dot {
    position: absolute;
    top: 50%;
    left: calc(-3rem - 0.25rem);
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--foreground);
    box-shadow: 0 0 0 0.25rem var(--background);
    transform: translateY(-50%);
  }

  .blog-post-row {
    display: grid;
    min-height: 5rem;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.5rem 2rem;
    color: var(--foreground);
    text-decoration: none;
  }

  .blog-post-title {
    margin: 0;
    font-size: clamp(1.125rem, 1.6vw, 1.2rem);
    font-weight: 400;
    line-height: 1.35;
    text-decoration: underline 1px transparent;
    text-underline-offset: 0.35rem;
    transition: text-decoration-color 180ms ease-out;
  }

  .blog-post-row:hover .blog-post-title {
    text-decoration-color: var(--foreground);
  }

  .blog-post-meta {
    margin: 0;
    font-size: 0.95rem;
    font-variant-numeric: tabular-nums;
    line-height: 1.4;
    white-space: nowrap;
    opacity: 0.62;
  }

  @media (max-width: 639px) {
    .blog-year-group {
      grid-template-columns: minmax(0, 1fr);
    }

    .blog-year-heading {
      padding: 0 0 0.6rem;
      font-size: 1.5rem;
    }

    .blog-year-posts {
      grid-column: 1;
      margin-left: 0.25rem;
      padding: 0.25rem 0 1.75rem 1.5rem;
    }

    .blog-timeline-dot {
      left: calc(-1.5rem - 0.25rem);
    }

    .blog-post-row {
      min-height: 4.25rem;
      grid-template-columns: minmax(0, 1fr);
      align-content: center;
      padding: 0.65rem 0.25rem;
    }

    .blog-post-title {
      font-size: 1.125rem;
    }

    .blog-post-meta {
      font-size: 0.875rem;
    }
  }
</style>

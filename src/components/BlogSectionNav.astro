---
interface Props {
  active: "blogs" | "category" | "talks";
}

const { active } = Astro.props;

const links = [
  { id: "blogs", label: "Blog", href: "/blog" },
  { id: "category", label: "Category", href: "/blog/category" },
  { id: "talks", label: "Talks", href: "/talks" },
];
---

<nav aria-label="内容分区" class="blog-section-nav">
  <ul class="blog-section-tabs">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class="blog-section-link"
            aria-current={active === link.id ? "page" : undefined}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .blog-section-nav {
    margin-bottom: clamp(1.5rem, 3.5vw, 2.25rem);
  }

  .blog-section-tabs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .blog-section-link {
    position: relative;
    display: inline-flex;
    min-height: 4.25rem;
    align-items: center;
    color: var(--foreground);
    font-family:
      "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino,
      Georgia, serif;
    font-size: clamp(1.65rem, 3.5vw, 2.15rem);
    font-weight: 400;
    line-height: 1;
    text-decoration: none;
    opacity: 0.52;
    transition: opacity 180ms ease-out;
  }

  .blog-section-link:hover {
    opacity: 0.8;
  }

  .blog-section-link[aria-current="page"] {
    opacity: 1;
  }

  .blog-section-link[aria-current="page"]::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 2px;
    background: var(--foreground);
    content: "";
  }

  @media (max-width: 479px) {
    .blog-section-tabs {
      gap: 1.25rem;
    }

    .blog-section-link {
      min-height: 3.75rem;
      font-size: 1.5rem;
    }
  }
</style>

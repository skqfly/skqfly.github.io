<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="切换到亮色模式"
  aria-pressed="false"
  title="切换到亮色模式"
>
  <span class="theme-toggle__icons" aria-hidden="true">
    <svg
      viewBox="0 0 24 24"
      width={24}
      height={24}
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      focusable="false"
      class="theme-toggle__icon theme-toggle__icon--sun"
    >
      <path d="M12 3V4M12 20V21M4 12H3M6.31412 6.31412L5.5 5.5M17.6859 6.31412L18.5 5.5M6.31412 17.69L5.5 18.5001M17.6859 17.69L18.5 18.5001M21 12H20M16 12C16 14.2091 14.2091 16 12 16C9.79086 16 8 14.2091 8 12C8 9.79086 9.79086 8 12 8C14.2091 8 16 9.79086 16 12Z" />
    </svg>
    <svg
      viewBox="0 0 24 24"
      width={24}
      height={24}
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      focusable="false"
      class="theme-toggle__icon theme-toggle__icon--moon"
    >
      <path d="M3.32031 11.6835C3.32031 16.6541 7.34975 20.6835 12.3203 20.6835C16.1075 20.6835 19.3483 18.3443 20.6768 15.032C19.6402 15.4486 18.5059 15.6834 17.3203 15.6834C12.3497 15.6834 8.32031 11.654 8.32031 6.68342C8.32031 5.50338 8.55165 4.36259 8.96453 3.32996C5.65605 4.66028 3.32031 7.89912 3.32031 11.6835Z" />
    </svg>
  </span>
</button>

<script>
  type Theme = "dark" | "light";

  type ViewTransitionDocument = Document & {
    startViewTransition?: (update: () => void) => {
      ready: Promise<void>;
    };
  };

  const root = document.documentElement;
  const toggle = document.getElementById("theme-toggle") as HTMLButtonElement;

  const syncToggle = (theme: Theme) => {
    const nextThemeLabel = theme === "dark" ? "亮色" : "暗色";
    const label = `切换到${nextThemeLabel}模式`;

    toggle.setAttribute("aria-label", label);
    toggle.setAttribute("title", label);
    toggle.setAttribute("aria-pressed", String(theme === "light"));
  };

  const applyTheme = (theme: Theme) => {
    root.dataset.theme = theme;
    syncToggle(theme);

    try {
      localStorage.setItem("theme", theme);
    } catch {
      // The selected theme still works when storage is unavailable.
    }
  };

  syncToggle(root.dataset.theme === "light" ? "light" : "dark");

  toggle.addEventListener("click", () => {
    const nextTheme: Theme = root.dataset.theme === "light" ? "dark" : "light";
    const isEnteringDark = nextTheme === "dark";
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    const viewTransitionDocument = document as ViewTransitionDocument;

    if (!viewTransitionDocument.startViewTransition || reduceMotion) {
      root.classList.toggle("theme-fallback", !reduceMotion);
      applyTheme(nextTheme);
      window.setTimeout(() => root.classList.remove("theme-fallback"), 300);
      return;
    }

    const { left, top, width, height } = toggle.getBoundingClientRect();
    const x = left + width / 2;
    const y = top + height / 2;
    const radius = Math.hypot(
      Math.max(x, window.innerWidth - x),
      Math.max(y, window.innerHeight - y)
    );
    const transitionClass = "theme-transition-to-dark";

    root.classList.toggle(transitionClass, isEnteringDark);

    const transition = viewTransitionDocument.startViewTransition(() => {
      applyTheme(nextTheme);
    });

    transition.ready
      .then(() => {
        const animation = root.animate(
          {
            clipPath: isEnteringDark
              ? [
                  `circle(${radius}px at ${x}px ${y}px)`,
                  `circle(0px at ${x}px ${y}px)`,
                ]
              : [
                  `circle(0px at ${x}px ${y}px)`,
                  `circle(${radius}px at ${x}px ${y}px)`,
                ],
          },
          {
            duration: isEnteringDark ? 520 : 720,
            easing: isEnteringDark
              ? "cubic-bezier(0.42, 0, 1, 1)"
              : "cubic-bezier(0.65, 0, 0.35, 1)",
            pseudoElement: isEnteringDark
              ? "::view-transition-old(root)"
              : "::view-transition-new(root)",
          } as KeyframeAnimationOptions & { pseudoElement: string }
        );

        animation.finished.then(
          () => root.classList.remove(transitionClass),
          () => root.classList.remove(transitionClass)
        );
      })
      .catch(() => {
        root.classList.remove(transitionClass);
        // The theme is already applied if the transition is interrupted.
      });
  });
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    width: 44px;
    height: 44px;
    flex: 0 0 44px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--foreground);
    opacity: 0.6;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .theme-toggle:hover {
    opacity: 1;
  }

  .theme-toggle:active {
    transform: scale(0.94);
  }

  .theme-toggle__icons {
    position: relative;
    display: block;
    width: 24px;
    height: 24px;
  }

  .theme-toggle__icon {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(0.72) rotate(-28deg);
    transition:
      opacity 180ms ease,
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(html[data-theme="dark"]) .theme-toggle__icon--sun {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  :global(html[data-theme="light"]) .theme-toggle__icon--moon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }
</style>

---
import { Icon } from "astro-icon/components";
import type { SocialLink } from "../types/config";

type Props = SocialLink;

const { title, url, icon, external } = Astro.props;
---

<a
  href={url}
  class="flex min-h-11 items-center gap-3 rounded-md px-1 opacity-60 transition-opacity group-hover:opacity-30 hover:!opacity-100"
  target={external ? "_blank" : "_self"}
  rel={external ? "noreferrer" : undefined}
  aria-label={external ? `${title}（在新窗口打开）` : title}
>
  <Icon name={icon} width={25} height={25} />
  <div>
    <p>{title}</p>
  </div>
</a>

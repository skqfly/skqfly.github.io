---
import { Icon } from "astro-icon/components";

interface Artwork {
  src: string;
  width: number;
  height: number;
  brand?: boolean;
}

interface Props {
  href: string;
  title: string;
  date: Date;
  artwork: Artwork;
  eager?: boolean;
}

const { href, title, date, artwork, eager = false } = Astro.props;

const dayFormatter = new Intl.DateTimeFormat("en", { day: "2-digit" });
const monthFormatter = new Intl.DateTimeFormat("en", { month: "short" });
const isoDate = date.toISOString().split("T")[0];
---

<a class="talk-row" href={href}>
  <time class="talk-date" datetime={isoDate}>
    <span class="talk-date__day">{dayFormatter.format(date)}</span>
    <span class="talk-date__month">{monthFormatter.format(date)}</span>
  </time>

  <span class="talk-artwork" aria-hidden="true">
    <span
      class:list={[
        "talk-artwork__stack",
        { "talk-artwork__stack--brand": artwork.brand },
      ]}
    >
      <img
        src={artwork.src}
        width={artwork.width}
        height={artwork.height}
        alt=""
        loading={eager ? "eager" : "lazy"}
        fetchpriority={eager ? "high" : "auto"}
        decoding="async"
      />
    </span>
  </span>

  <h3 class="talk-title">{title}</h3>

  <span class="talk-arrow" aria-hidden="true">
    <Icon name="mdi:chevron-right" width={25} height={25} />
  </span>
</a>

<style>
  .talk-row {
    display: grid;
    min-height: 7.25rem;
    grid-template-columns: 4.75rem 6.75rem minmax(0, 1fr) 2.75rem;
    align-items: center;
    gap: 1rem;
    color: var(--foreground);
    text-decoration: none;
  }

  .talk-date {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .talk-date__day {
    font-size: 1.65rem;
    line-height: 1;
  }

  .talk-date__month {
    font-size: 0.8rem;
    opacity: 0.58;
    text-transform: uppercase;
  }

  .talk-artwork {
    display: grid;
    width: 6.25rem;
    height: 4.5rem;
    place-items: center;
  }

  .talk-artwork__stack {
    position: relative;
    display: block;
    width: 5.75rem;
    height: 4.25rem;
  }

  .talk-artwork__stack::before,
  .talk-artwork__stack::after {
    position: absolute;
    inset: 0;
    border: 1px solid var(--border);
    border-radius: 0.45rem;
    background: var(--surface);
    content: "";
  }

  .talk-artwork__stack::before {
    transform: translate(0.45rem, 0.1rem) rotate(4deg);
  }

  .talk-artwork__stack::after {
    transform: translate(0.22rem, 0.05rem) rotate(2deg);
  }

  .talk-artwork__stack img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 0.45rem;
    object-fit: cover;
    transition:
      filter 180ms ease-out,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .talk-artwork__stack--brand img {
    padding: 0.35rem;
    background: #ffffff;
    object-fit: contain;
  }

  .talk-title {
    margin: 0;
    font-family:
      "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino,
      Georgia, serif;
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    font-weight: 400;
    line-height: 1.4;
  }

  .talk-arrow {
    display: inline-flex;
    width: 2.75rem;
    height: 2.75rem;
    align-items: center;
    justify-content: center;
    opacity: 0.44;
    transition:
      opacity 180ms ease-out,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .talk-row:hover .talk-artwork__stack img {
    filter: brightness(0.9);
    transform: translateY(-0.1rem);
  }

  .talk-row:hover .talk-arrow {
    opacity: 0.9;
    transform: translateX(0.2rem);
  }

  @media (max-width: 639px) {
    .talk-row {
      min-height: 6.25rem;
      grid-template-columns: 3rem 4.5rem minmax(0, 1fr) 2.75rem;
      gap: 0.65rem;
    }

    .talk-date {
      align-items: center;
      flex-direction: column;
      gap: 0.2rem;
    }

    .talk-date__day {
      font-size: 1.35rem;
    }

    .talk-date__month {
      font-size: 0.7rem;
    }

    .talk-artwork {
      width: 4.25rem;
      height: 4.25rem;
    }

    .talk-artwork__stack {
      width: 3.85rem;
      height: 3.85rem;
    }

    .talk-title {
      font-size: 1rem;
      line-height: 1.35;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .talk-artwork__stack img,
    .talk-arrow {
      transition: none;
    }
  }
</style>

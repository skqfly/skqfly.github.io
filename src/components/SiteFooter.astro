---
import { Icon } from "astro-icon/components";

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <a class="site-footer__home" href="/" aria-label="Back to home">
      <Icon
        class="site-footer__home-icon"
        name="mdi:home-outline"
        width={19}
        height={19}
        aria-hidden="true"
      />
      <span>Back to home</span>
    </a>

    <p class="site-footer__copyright">
      © {currentYear} skqfly. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    padding:
      0 clamp(1rem, 4vw, 2rem)
      calc(3.5rem + env(safe-area-inset-bottom));
  }

  .site-footer__inner {
    display: flex;
    width: 100%;
    max-width: 48rem;
    align-items: center;
    flex-direction: column;
    gap: 0.65rem;
    margin: 0 auto;
    color: var(--foreground);
    font-family:
      "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino,
      Georgia, serif;
    text-align: center;
  }

  .site-footer__home {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 0.42rem;
    color: inherit;
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    font-weight: 400;
    line-height: 1;
    text-decoration: none;
    opacity: 0.72;
    transition:
      opacity 180ms ease-out,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-footer__home-icon {
    flex: 0 0 auto;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-footer__home:hover {
    opacity: 1;
    transform: translateY(-1px);
  }

  .site-footer__home:hover .site-footer__home-icon {
    transform: translateY(-2px);
  }

  .site-footer__copyright {
    margin: 0;
    font-size: clamp(0.82rem, 1.4vw, 0.96rem);
    letter-spacing: 0.015em;
    line-height: 1.5;
    opacity: 0.48;
  }

  @media (max-width: 639px) {
    .site-footer {
      padding-bottom: calc(2.75rem + env(safe-area-inset-bottom));
    }

    .site-footer__inner {
      gap: 0.45rem;
    }

    .site-footer__home {
      gap: 0.4rem;
      font-size: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-footer__home,
    .site-footer__home-icon {
      transition: none;
    }
  }
</style>

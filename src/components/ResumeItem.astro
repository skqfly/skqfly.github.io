---
import { Image } from "astro:assets";
import type { ResumeItem } from "../types/config";

type Props = ResumeItem;

const { title, company, date } = Astro.props;
---

<a
  href={company.url}
  target="_blank"
  rel="noreferrer"
  class="flex items-center justify-between gap-4 py-3 transition-opacity group-hover:opacity-60 hover:!opacity-100"
>
  <div class="flex min-w-0 items-center gap-4">
    <Image
      src={company.image}
      alt={company.name}
      width={40}
      height={40}
      class="brand-mark w-[40px] h-[40px] object-contain"
    />
    <div class="min-w-0">
      <h3 class="font-medium">{title}</h3>
      <p class="break-words text-sm opacity-60">{company.name}</p>
    </div>
  </div>
  <p class="shrink-0 text-sm opacity-60">{date}</p>
</a>
